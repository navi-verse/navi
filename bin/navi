#!/usr/bin/env bash
set -euo pipefail

# Resolve the project root (follow symlinks: /usr/local/bin/navi → <project>/bin/navi)
SCRIPT="$0"
if [[ -L "$SCRIPT" ]]; then
	SCRIPT="$(readlink "$SCRIPT")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

NAVI_HOME="$HOME/.navi"
PLIST_NAME="com.navi.agent"
PLIST_PATH="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"
STDOUT_LOG="$NAVI_HOME/navi.out.log"
STDERR_LOG="$NAVI_HOME/navi.err.log"
DOMAIN="gui/$(id -u)"

generate_plist() {
	mkdir -p "$(dirname "$PLIST_PATH")"
	local tsx_bin="$PROJECT_DIR/node_modules/.bin/tsx"
	cat > "$PLIST_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>$PLIST_NAME</string>
	<key>ProgramArguments</key>
	<array>
		<string>$tsx_bin</string>
		<string>$PROJECT_DIR/src/index.ts</string>
	</array>
	<key>WorkingDirectory</key>
	<string>$PROJECT_DIR</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>$(dirname "$(which node)"):$PATH</string>
		<key>HOME</key>
		<string>$HOME</string>
	</dict>
	<key>StandardOutPath</key>
	<string>$STDOUT_LOG</string>
	<key>StandardErrorPath</key>
	<string>$STDERR_LOG</string>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>10</integer>
</dict>
</plist>
EOF
	echo "Plist written to $PLIST_PATH"
}

is_loaded() {
	launchctl print "$DOMAIN/$PLIST_NAME" &>/dev/null
}

link_cli() {
	local target="/usr/local/bin/navi"
	local source="$SCRIPT_DIR/navi"
	if [[ -L "$target" && "$(readlink "$target")" == "$source" ]]; then
		return # already linked
	fi
	echo "Linking navi to $target..."
	if [[ -w "$(dirname "$target")" ]]; then
		ln -sf "$source" "$target"
	else
		sudo ln -sf "$source" "$target"
	fi
	echo "You can now run 'navi' from anywhere."
}

cmd_install() {
	preflight
	generate_plist
	link_cli
	if is_loaded; then
		launchctl bootout "$DOMAIN/$PLIST_NAME" 2>/dev/null || true
	fi
	launchctl bootstrap "$DOMAIN" "$PLIST_PATH"
	echo "Navi installed and started."
}

cmd_uninstall() {
	if is_loaded; then
		launchctl bootout "$DOMAIN/$PLIST_NAME" 2>/dev/null || true
		echo "Service stopped."
	fi
	if [[ -f "$PLIST_PATH" ]]; then
		rm "$PLIST_PATH"
		echo "Plist removed."
	fi
	local target="/usr/local/bin/navi"
	if [[ -L "$target" && "$(readlink "$target")" == "$SCRIPT_DIR/navi" ]]; then
		rm "$target" 2>/dev/null || sudo rm "$target"
		echo "CLI symlink removed."
	fi
	echo "Navi uninstalled."
}

cmd_start() {
	preflight
	if ! [[ -f "$PLIST_PATH" ]]; then
		echo "Not installed. Run: navi install"
		exit 1
	fi
	if is_loaded; then
		echo "Already running."
		exit 0
	fi
	launchctl bootstrap "$DOMAIN" "$PLIST_PATH"
	echo "Navi started."
}

cmd_stop() {
	if is_loaded; then
		launchctl bootout "$DOMAIN/$PLIST_NAME" 2>/dev/null || true
		echo "Navi stopped."
	else
		echo "Not running."
	fi
}

preflight() {
	local ok=true
	command -v node &>/dev/null || { echo "❌ node not found"; ok=false; }
	[[ -d "$PROJECT_DIR/node_modules" ]] || { echo "❌ node_modules missing — run: npm install"; ok=false; }
	[[ -x "$PROJECT_DIR/node_modules/.bin/tsx" ]] || { echo "❌ tsx missing — run: npm install"; ok=false; }
	[[ -f "$NAVI_HOME/auth.json" ]] || { echo "❌ auth.json missing — run: npm run login"; ok=false; }
	$ok || { echo "Fix the issues above first."; exit 1; }
}

cmd_restart() {
	preflight
	cmd_stop
	sleep 1
	cmd_start
}

cmd_status() {
	if is_loaded; then
		local pid
		pid=$(launchctl print "$DOMAIN/$PLIST_NAME" 2>/dev/null | grep -m1 'pid =' | awk '{print $3}')
		if [[ -n "$pid" && "$pid" != "0" ]]; then
			echo "Navi is running (pid $pid)"
		else
			echo "Navi is loaded but not currently running (will restart)"
		fi
	else
		echo "Navi is not running."
	fi
}

cmd_log() {
	if [[ ! -f "$STDOUT_LOG" ]]; then
		echo "No log file yet. Is Navi installed?"
		exit 1
	fi
	tail -f "$STDOUT_LOG"
}

cmd_update() {
	echo "Pulling latest..."
	(cd "$PROJECT_DIR" && git pull)
	echo "Installing dependencies..."
	(cd "$PROJECT_DIR" && npm install)
	preflight
	echo "Type-checking..."
	(cd "$PROJECT_DIR" && "$PROJECT_DIR/node_modules/.bin/tsc" --noEmit)
	echo "OK."
	if is_loaded; then
		echo "Restarting..."
		cmd_stop
		sleep 1
		cmd_start
	fi
}

cmd_version() {
	local tag commit desc
	tag=$(cd "$PROJECT_DIR" && git describe --tags --abbrev=0 2>/dev/null || echo "untagged")
	commit=$(cd "$PROJECT_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
	desc=$(cd "$PROJECT_DIR" && git describe --tags --long 2>/dev/null || echo "")
	if [[ -n "$desc" && "$desc" == *-0-g* ]]; then
		echo "Navi $tag ($commit)"
	elif [[ -n "$desc" ]]; then
		local ahead
		ahead=$(echo "$desc" | sed 's/.*-\([0-9]*\)-g.*/\1/')
		echo "Navi $tag+$ahead ($commit)"
	else
		echo "Navi $commit"
	fi
}

cmd_doctor() {
	local ok=true

	# Version
	cmd_version
	echo ""

	# Node
	if command -v node &>/dev/null; then
		echo "✅ node $(node --version)"
	else
		echo "❌ node not found"
		ok=false
	fi

	# npm
	if command -v npm &>/dev/null; then
		echo "✅ npm $(npm --version)"
	else
		echo "❌ npm not found"
		ok=false
	fi

	# node_modules
	if [[ -d "$PROJECT_DIR/node_modules" ]]; then
		echo "✅ node_modules installed"
	else
		echo "❌ node_modules missing — run: npm install"
		ok=false
	fi

	# tsx
	if [[ -x "$PROJECT_DIR/node_modules/.bin/tsx" ]]; then
		echo "✅ tsx available"
	else
		echo "❌ tsx missing — run: npm install"
		ok=false
	fi

	# Auth
	if [[ -f "$NAVI_HOME/auth.json" ]]; then
		# Check if any provider has credentials
		local providers
		providers=$(node -e "
			const a = require('$NAVI_HOME/auth.json');
			const p = Object.keys(a).filter(k => a[k]);
			if (p.length) console.log(p.join(', '));
		" 2>/dev/null || echo "")
		if [[ -n "$providers" ]]; then
			echo "✅ auth.json ($providers)"
		else
			echo "⚠️  auth.json exists but no providers logged in — run: npm run login"
		fi
	else
		echo "❌ auth.json missing — run: npm run login"
		ok=false
	fi

	# Model
	if [[ -f "$NAVI_HOME/settings.json" ]]; then
		local model
		model=$(node -e "
			const s = require('$NAVI_HOME/settings.json');
			if (s.model) console.log(s.model);
		" 2>/dev/null || echo "")
		if [[ -n "$model" ]]; then
			echo "✅ model: $model"
		else
			echo "⚠️  no model configured — will auto-select from logged-in provider"
		fi
	else
		echo "⚠️  settings.json missing — will be created on first run"
	fi

	# Service
	if is_loaded; then
		echo "✅ service running"
	elif [[ -f "$PLIST_PATH" ]]; then
		echo "⚠️  service installed but not running"
	else
		echo "⚠️  service not installed — run: navi install"
	fi

	echo ""
	if $ok; then
		echo "All good."
	else
		echo "Fix the issues above before running Navi."
	fi
}

case "${1:-help}" in
	install)   cmd_install ;;
	uninstall) cmd_uninstall ;;
	start)     cmd_start ;;
	stop)      cmd_stop ;;
	restart)   cmd_restart ;;
	status)    cmd_status ;;
	log)       cmd_log ;;
	update)    cmd_update ;;
	doctor)    cmd_doctor ;;
	version)   cmd_version ;;
	help|*)
		echo "Usage: navi <command>"
		echo ""
		echo "  install    Install as launchd service"
		echo "  uninstall  Stop and remove the service"
		echo "  start      Start the service"
		echo "  stop       Stop the service"
		echo "  restart    Restart the service"
		echo "  update     Pull latest, install deps, and restart"
		echo "  doctor     Preflight check (deps, auth, model)"
		echo "  version    Show current version"
		echo "  status     Show if Navi is running"
		echo "  log        Tail the live log"
		;;
esac
