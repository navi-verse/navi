{
	"name": "nv",
	"version": "0.1.0",
	"description": "WhatsApp bot powered by an LLM agent",
	"type": "module",
	"bin": {
		"nv": "dist/main.js"
	},
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json && chmod +x dist/main.js",
		"install-global": "npm run build && npm install -g .",
		"dev": "npx tsx --watch-path src --watch src/main.ts run",
		"start": "npx tsx src/main.ts run",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit",
		"login:claude": "npx tsx src/main.ts --login anthropic",
		"login:codex": "npx tsx src/main.ts --login openai-codex"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.61.1",
		"@mariozechner/pi-ai": "^0.61.1",
		"@mariozechner/pi-coding-agent": "^0.61.1",
		"@sinclair/typebox": "^0.34.0",
		"baileys": "^7.0.0-rc.9",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"qrcode-terminal": "^0.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"@types/qrcode-terminal": "^0.12.0",
		"tsx": "^4.20.3",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"license": "MIT"
}
