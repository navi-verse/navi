{
  "name": "navi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "login": "tsx src/login.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && biome check --write src/",
    "ci": "tsc --noEmit && biome check src/"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.58.1",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "croner": "^10.0.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
